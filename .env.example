# Obtenha sua chave em: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Chave secreta do Flask (mude em produção)
SECRET_KEY=change-this-to-a-random-string

# Chave para assinar os JWT (se omitida, usa SECRET_KEY)
JWT_SECRET_KEY=change-this-to-another-random-string

# URL do banco — sobrescreva para PostgreSQL se desejar
# DATABASE_URL=sqlite:///cinerate.db
